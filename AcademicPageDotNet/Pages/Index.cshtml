@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["Name"] = "Yuyang Li";
}

<div class="text-left">
    <table>
        <tr>
            <td style="padding:2.5%;width:35%;max-width:35%">
                <img src="@Model.Personal["AvatarUrl"]" style="width:100%;max-width:100%" alt="profile photo">
            </td>
            <td style="padding:2.5%;width:65%;vertical-align:middle">
                <h3 class="text-center" style="font-size:2.0rem">@Model.Personal["Name"]</h3>
                <h5 class="text-center" style="font-size:1.0rem">@Model.Personal["Role"] at @Model.Personal["Institute"]</h5>
                <p>
                    I am currently a junior student in the <a href="https://www.au.tsinghua.edu.cn/"
                                                              target="_blank">Department&nbsp;of&nbsp;Automation</a> at <a href="https://www.tsinghua.edu.cn">Tsinghua&nbsp;University</a>. I joined the <a href="https://tongclass.ac.cn/">Tong&nbsp;Class</a> (an AGI program founded by <a href="http://www.stat.ucla.edu/~sczhu/">Prof.&nbsp;Song-Chun&nbsp;Zhu</a>), being a member and the
                    technical leader in the class of 2020.
                    I am currently a research intern at General Vision Lab, <a href="https://bigai.ai">BIGAI</a>, and I'm
                    grateful to be advised by <a href="http://tengyu.ai/">Tengyu&nbsp;Liu</a>.
                </p>
                <p>
                    My research interests lie in the intersection of 3D computer vision, computer graphics, and robotics. My
                    long-term goal is to create intelligence that perceives, understands, and interacts with the physical /
                    virtual
                    environments. Currently, I am working on dexterous grasping & manipulation. I also look forward to
                    stepping into
                    scene understanding and visually grounded reasoning.
                </p>
                <p>
                    I am also interested in network technologies. I work as a core member in the technical group of THU Student Network Service (SNS), responsible for the team's server
                    operations and service maintenance.
                </p>
            </td>
        </tr>
    </table>


    <div class="container">
        <section class="text-center mb-5">
            @if (Model.Personal["Email"] != "")
            {
                <a target="_blank" href="mailto:@Model.Links["CV"]" class="text-white me-4"><i class="bi bi-envelope-fill"></i></a>
            }
            @if (Model.Links["CV"] != "")
            {
                <a target="_blank" href="@Model.Links["CV"]" class="text-white me-4"><i class="ai ai-cv"></i></a>
            }
            @if (Model.Links["GitHub"] != "")
            {
                <a target="_blank" href="@Model.Links["GitHub"]" class="text-white me-4"><i class="bi bi-github"></i></a>
            }
            @if (Model.Links["Twitter"] != "")
            {
                <a target="_blank" href="@Model.Links["Twitter"]" class="text-white me-4"><i class="bi bi-twitter"></i></a>
            }
            @if (Model.Links["GoogleScholar"] != "")
            {
                <a target="_blank" href="@Model.Links["GoogleScholar"]" class="text-white me-4"><i class="ai ai-google-scholar"></i></a>
            }
            @if (Model.Links["LinkedIn"] != "")
            {
                <a target="_blank" href="@Model.Links["LinkedIn"]" class="text-white me-4"><i class="bi bi-linkedin"></i></a>
            }
            @if (Model.Links["ORCID"] != "")
            {
                <a target="_blank" href="@Model.Links["ORCID"]" class="text-white me-4"><i class="ai ai-orcid"></i></a>
            }
            @if (Model.Links["Instagram"] != "")
            {
                <a target="_blank" href="@Model.Links["Instagram"]" class="text-white me-4"><i class="bi bi-instagram"></i></a>
            }
            @if (Model.Links["Photography"] != "")
            {
                <a target="_blank" href="@Model.Links["Photography"]" class="text-white me-4"><i class="bi bi-images"></i></a>
            }
        </section>
    </div>
</div>
